# Engine RUL Prediction System — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then start everything with:
#   docker compose up

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=prognosai
DB_USER=postgres
DB_PASSWORD=ruldb_secret               # pre-set default — change only for production

# ── Grafana ───────────────────────────────────────────────────────────────────
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=admin                # Change for production deployments

# ── Docker Hub namespace ──────────────────────────────────────────────────────
DOCKER_HUB_USER=amalsalilan
